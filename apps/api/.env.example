# ─────────────────────────────────────────────────────────────
#  Relay API configuration
#  Copy to ".env" (pnpm bootstrap does this automatically).
# ─────────────────────────────────────────────────────────────

# Port the API listens on. Must match NEXT_PUBLIC_API_URL in the web app.
PORT=4002

# Browser origin allowed by CORS. Defaults to reflecting any origin in dev;
# set an explicit URL in production, e.g. https://relay.example.com
# WEB_ORIGIN=http://localhost:3002

# ── Metadata store ───────────────────────────────────────────
# Relay's OWN SQLite file (saved connections) — NOT a database you connect to.
# Path is resolved relative to apps/api/prisma/.
DATABASE_URL="file:./relay.db"

# ── Security ─────────────────────────────────────────────────
# Base64 32-byte key encrypting stored connection credentials (AES-256-GCM).
# Leave blank for local dev — a key is generated under apps/api/.relay/.
# For production, set this and keep it secret:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
RELAY_MASTER_KEY=

# ── Limits / tuning ──────────────────────────────────────────
# Hard cap on rows returned by a single ad-hoc query.
RELAY_MAX_QUERY_ROWS=5000
# Idle milliseconds before a pooled database connection is closed.
RELAY_POOL_IDLE_MS=300000
# Where the encryption key + local state live (default: apps/api/.relay).
# RELAY_DATA_DIR=.relay

# ── Automation hooks (job queue) ─────────────────────────────
# Redis backing the BullMQ queue that runs automation hooks. Start one with
# `docker compose up -d redis` from the repo root. The studio, hook CRUD and
# payload preview work without Redis — only *running* a hook needs it.
REDIS_URL=redis://localhost:6379
# How many hook runs may execute concurrently.
RELAY_HOOK_CONCURRENCY=5
